{
  "name": "@kingdomcord/bot",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env ts-node-dev --require tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "deploy:commands": "DOTENV_CONFIG_PATH=../../.env ts-node --transpile-only src/scripts/deployCommands.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@discordjs/voice": "^0.17.0",
    "@kingdomcord/db": "*",
    "@kingdomcord/shared": "*",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "openai": "^4.52.0",
    "pino": "^9.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
